{
  "title": "EU AI Act RAG",
  "uid": "eu-ai-act-rag",
  "schemaVersion": 39,
  "editable": true,
  "timezone": "browser",
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "10s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Latency P50 / P95 / P99",
      "type": "timeseries",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(rag_latency_seconds_bucket[5m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, rate(rag_latency_seconds_bucket[5m]))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, rate(rag_latency_seconds_bucket[5m]))", "legendFormat": "p99" }
      ]
    },
    {
      "id": 2,
      "title": "Request rate (req/min)",
      "type": "timeseries",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "sum by (status) (rate(rag_requests_total[5m])) * 60", "legendFormat": "{{status}}" }
      ]
    },
    {
      "id": 3,
      "title": "Cache hit rate",
      "type": "stat",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } },
      "targets": [
        { "expr": "rate(rag_cache_hits_total[5m]) / clamp_min(rate(rag_requests_total[5m]), 0.0001)" }
      ]
    },
    {
      "id": 4,
      "title": "Error rate",
      "type": "stat",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } },
      "targets": [
        { "expr": "rate(rag_requests_total{status=\"error\"}[5m]) / clamp_min(rate(rag_requests_total[5m]), 0.0001)" }
      ]
    },
    {
      "id": 5,
      "title": "References per response (avg)",
      "type": "timeseries",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "targets": [
        { "expr": "rate(rag_reference_count_sum[5m]) / clamp_min(rate(rag_reference_count_count[5m]), 0.0001)", "legendFormat": "avg refs" }
      ]
    }
  ]
}
