# ---------------------------------------------------------------------------
# EU AI Act RAG — environment configuration
# Copy to `.env` and adjust. All defaults work for a local single-node run.
# On Demetra, point the *_URL hosts at the compute node running the Apptainer
# instances (see slurm/ and CLAUDE.md).
# ---------------------------------------------------------------------------

# LLM (OpenAI-compatible server: SGLang, or llama.cpp serving gemma-4-31B)
SGLANG_BASE_URL=http://localhost:8899/v1
LLM_MODEL=default
UTILITY_MODEL=default
# Reasoning models (gemma-4) stream chain-of-thought in a separate
# reasoning_content field BEFORE the answer. With thinking on, a small
# max_tokens budget is consumed by reasoning and `content` returns empty.
# Keep thinking off for the competition: complete JSON answer + lower latency.
LLM_MAX_TOKENS=512
LLM_ENABLE_THINKING=false

# Embedding (local SentenceTransformer model)
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_DIM=1024

# Qdrant. Leave QDRANT_URL set to use a running server; set QDRANT_LOCAL_PATH
# instead (and clear QDRANT_URL) to use the embedded on-disk mode (no server).
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=eu_ai_act
# QDRANT_LOCAL_PATH=./data/qdrant

# Redis. If unreachable, the semantic cache transparently falls back to an
# in-process LRU cache so the API keeps serving.
REDIS_URL=redis://localhost:6379/0

# LightRAG knowledge-graph working directory
LIGHTRAG_WORKING_DIR=./lightrag_data
# Graph query mode: "mix"/"local"/"global" make an LLM keyword-extraction call
# per query (heaviest step); "naive" is pure vector search (no LLM, lower
# latency, loses graph traversal). Default mix; set naive to prioritise latency.
LIGHTRAG_MODE=mix

# Reranker (BGE cross-encoder + optional second-stage LLM rerank)
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_TOP_K=5
# Second-stage LLM rerank over the BGE candidates (adaptive query-centered
# snippets; falls back to BGE order on any error). Set false for BGE only.
ENABLE_LLM_RERANK=true
# Multi-chunk voting rerank (default ON; A/B raised ref recall 85%->92%):
# LLM-rank an un-deduped pool of RERANK_CANDIDATE_CHUNKS chunks, then vote per
# article. Recovers articles whose answering chunk the pre-rerank dedup dropped.
# Set false to fall back to one-chunk-per-article reranking.
ENABLE_CHUNK_VOTING=true
RERANK_CANDIDATE_CHUNKS=12
# Pool-blend (voting mode only, default off pending A/B): reserve the top
# POOL_RRF_RESERVE RRF candidates in the vote pool before filling by BGE, so a
# strong fusion signal isn't buried by a low cross-encoder score (comp_27).
ENABLE_POOL_BLEND=false
POOL_RRF_RESERVE=4

# BM25 index location
BM25_INDEX_DIR=./bm25_index

# Semantic cache. 0.97 is deliberately strict — legal Q&A needs near-identical
# phrasing before reusing a cached answer (0.95 collided distinct questions).
# CACHE_REQUIRE_REF_MATCH gates semantic hits on an exact ref-set match.
CACHE_TTL_SECONDS=3600
CACHE_SIMILARITY_THRESHOLD=0.97
CACHE_REQUIRE_REF_MATCH=true

# Reciprocal Rank Fusion weights
RRF_WEIGHT_EXACT=3.0
RRF_WEIGHT_DENSE=1.0
RRF_WEIGHT_BM25=0.6
RRF_WEIGHT_GRAPH=0.9
# Cross-reference expansion (provisions cited inside retrieved chunks).
RRF_WEIGHT_XREF=0.5
RRF_K=60
