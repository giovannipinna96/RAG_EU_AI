# ---------------------------------------------------------------------------
# EU AI Act RAG — Docker Compose configuration.
# Copy to .env.docker and set SGLANG_BASE_URL. Everything else is a sane default
# for the portable CPU deployment (see DEPLOY.md).
#     cp .env.docker.example .env.docker
# ---------------------------------------------------------------------------

# === THE ONLY LINE YOU MUST EDIT =============================================
# OpenAI-compatible LLM endpoint reachable FROM THIS HOST. Must end in /v1.
# The lab gemma server (http://172.30.42.129:8080/v1) is only reachable from the
# Demetra login node — from any other machine, point this at an LLM you can
# actually reach (a local llama.cpp/vLLM server, a hosted OpenAI-compatible API,
# an SSH tunnel, ...). If unreachable, the API starts but fresh queries fail.
SGLANG_BASE_URL=http://CHANGE_ME:8080/v1
# =============================================================================

# Model name as the endpoint expects it (llama.cpp GGUF filename, or an API id).
LLM_MODEL=gemma-4-26B-A4B-it-BF16-00001-of-00002.gguf
UTILITY_MODEL=gemma-4-26B-A4B-it-BF16-00001-of-00002.gguf
LLM_MAX_TOKENS=512
LLM_ENABLE_THINKING=false

# Embedding (baked into the image; runs on CPU here).
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_DIM=1024

# Qdrant — EMBEDDED on-disk (baked into the image at /app/data/qdrant).
QDRANT_LOCAL_PATH=./data/qdrant
QDRANT_COLLECTION=eu_ai_act

# Redis — the compose `redis` service (persistent semantic cache).
REDIS_URL=redis://redis:6379/0

# LightRAG knowledge-graph store (baked in). "mix" = LLM keyword extraction in
# parallel (near-free latency); "naive" = pure vector, no LLM.
LIGHTRAG_WORKING_DIR=./lightrag_data
LIGHTRAG_MODE=mix

# Reranker (baked into the image; CPU cross-encoder). Second-stage LLM rerank and
# chunk voting stay OFF for latency (each adds a gemma round-trip per query).
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_TOP_K=5
ENABLE_LLM_RERANK=false
ENABLE_CHUNK_VOTING=false
RERANK_CANDIDATE_CHUNKS=12
RERANK_LLM_SNIPPET_CHARS=3000
ENABLE_POOL_BLEND=false
POOL_RRF_RESERVE=4

# BM25 index (baked in).
BM25_INDEX_DIR=./bm25_index

# Semantic cache. 0.97 is deliberately strict for legal Q&A; ref-match gates hits.
CACHE_TTL_SECONDS=86400
CACHE_SIMILARITY_THRESHOLD=0.97
CACHE_REQUIRE_REF_MATCH=true

# Reciprocal Rank Fusion weights.
RRF_WEIGHT_EXACT=3.0
RRF_WEIGHT_DENSE=1.0
RRF_WEIGHT_BM25=0.6
RRF_WEIGHT_GRAPH=0.9
RRF_WEIGHT_XREF=0.5
RRF_K=60
