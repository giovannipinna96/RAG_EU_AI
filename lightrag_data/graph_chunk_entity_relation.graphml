</node>
<node id="Article 51">
  <data key="d0">Article 51</data>
  <data key="d1">concept</data>
  <data key="d2">Article 51 defines conditions for high impact capabilities and the designation of models as having systemic risks.</data>
  <data key="d3">chunk-91245f3945c3d7cc7ebcd77b066b7ef9</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1779828340</data>
