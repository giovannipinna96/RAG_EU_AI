  <data key="d12">1779828351</data>
  <data key="d13"></data>
</edge>
<edge source="Commission" target="Technical Documentation">
  <data key="d7">1.0</data>
  <data key="d8">The Commission oversees the inclusion of the post-market monitoring plan in the technical documentation as per Annex IV.</data>
  <data key="d9">legislation,oversight</data>
  <data key="d10">chunk-8c4a20c7ba57c9d3c1ba3d58548d1390</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1779828351</data>
  <data key="d13"></data>
</edge>
<edge source="Commission" target="Member States">
  <data key="d7">5.0</data>
  <data key="d8">The Commission provides guidance and cooperates with Member States on the application of the Regulation.&lt;SEP&gt;Member States inform the Commission about measures and disputes regarding AI systems.&lt;SEP&gt;The Commission oversees and coordinates with Member States on AI regulatory issues.&lt;SEP&gt;The Commission guides Member States in laying down rules and implementing penalties.&lt;SEP&gt;Member States provide information to the Commission upon request.</data>
  <data key="d9">compliance,cooperation,coordination,enforcement,guidance,information request,regulatory oversight</data>
  <data key="d10">chunk-d9ca73b5aa4562e502c8b54d80b9091a&lt;SEP&gt;chunk-3b09e19ff232fc74f764b77ba6bcc3f4&lt;SEP&gt;chunk-38169246e9fa46f9e17ff295ac3346d7&lt;SEP&gt;chunk-06bc0ddf887512f18d0e6f10df7767fa</data>
