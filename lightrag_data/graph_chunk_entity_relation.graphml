<node id="Complaint">
  <data key="d0">Complaint</data>
  <data key="d1">content</data>
  <data key="d2">A Complaint is a formal request alleging an infringement of this Regulation or a violation by a provider of a general-purpose AI model.</data>
  <data key="d3">chunk-51ee6686c61ba5ea54245e3aa87b1783</data>
  <data key="d4">unknown_source</data>
