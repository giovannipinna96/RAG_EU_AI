<node id="Article 52">
  <data key="d0">Article 52</data>
  <data key="d1">concept</data>
  <data key="d2">Article 52 specifies the procedure for notification and the options for providing substantiated arguments to avoid designation as a model with systemic risk.</data>
  <data key="d3">chunk-91245f3945c3d7cc7ebcd77b066b7ef9</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1779828340</data>
  <data key="d6"></data>
</node>
<node id="Annex XIII">
  <data key="d0">Annex XIII</data>
  <data key="d1">data</data>
  <data key="d2">Annex XIII contains criteria for high impact capabilities and systemic risks as well as specifications for updating those criteria.&lt;SEP&gt;Annex XIII contains criteria for designating general-purpose AI models with systemic risk.</data>
