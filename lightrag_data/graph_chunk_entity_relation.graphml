  <data key="d5">1779828342</data>
  <data key="d6"></data>
</node>
<node id="Subliminal Techniques">
  <data key="d0">Subliminal Techniques</data>
  <data key="d1">concept</data>
  <data key="d2">Subliminal Techniques are methods designed to influence a person's behavior without their conscious awareness.</data>
  <data key="d3">chunk-6d534e37e8a91e087b0f7afd91260337</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1779828342</data>
  <data key="d6"></data>
</node>
<node id="Manipulative or Deceptive Techniques">
  <data key="d0">Manipulative or Deceptive Techniques</data>
  <data key="d1">concept</data>
  <data key="d2">Manipulative or Deceptive Techniques are methods intended to distort behavior by subconsciously affecting a person.</data>
  <data key="d3">chunk-6d534e37e8a91e087b0f7afd91260337</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1779828342</data>
