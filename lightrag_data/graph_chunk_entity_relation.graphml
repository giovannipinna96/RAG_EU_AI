</node>
<node id="Right to Explanation">
  <data key="d0">Right to Explanation</data>
  <data key="d1">concept</data>
  <data key="d2">The Right to Explanation grants affected persons the ability to request clear and meaningful explanations from the AI deployer regarding the role of the AI in decision-making processes.</data>
  <data key="d3">chunk-51ee6686c61ba5ea54245e3aa87b1783</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1779828347</data>
