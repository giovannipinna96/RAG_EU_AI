<node id="Union">
  <data key="d0">Union</data>
  <data key="d1">location</data>
  <data key="d2">Union is a placeholder for the European Union, a geopolitical and economic union that oversees the regulation of AI systems.&lt;SEP&gt;Union refers to the European Union.&lt;SEP&gt;Union refers to the European Union, the governing body that outlines the regulatory framework for AI systems.&lt;SEP&gt;Union refers to the European Union, the governing body overseeing the regulation and codes of practice development.&lt;SEP&gt;Union refers to the European Union, a political and economic union of 27 member states in Europe.&lt;SEP&gt;The Union refers to the European Union where the registered business users are established.</data>
  <data key="d3">chunk-037b3133eed3c3d2ae1057711af7caab&lt;SEP&gt;chunk-9d94f80b79b953201dabec0b31eb7d1f&lt;SEP&gt;chunk-bde5afcadc1bd6c8b37d30bd93e7d045&lt;SEP&gt;chunk-95f4bd1a2188c8af0ad581dae55c8d76&lt;SEP&gt;chunk-3b09e19ff232fc74f764b77ba6bcc3f4&lt;SEP&gt;chunk-1ba7997e7cc9a9c81f53126131569e4a&lt;SEP&gt;chunk-33b3b690e83a48d4f90c85be3eebb646</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1779828334</data>
  <data key="d6"></data>
</node>
<node id="Organisational Needs">
  <data key="d0">Organisational Needs</data>
  <data key="d1">concept</data>
  <data key="d2">Organisational Needs refer to the requirements or demands made by an organisation to manage its operations efficiently.</data>
  <data key="d3">chunk-9bbabb917a8fd4d1cab0f28da3292879</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1779828334</data>
  <data key="d6"></data>
</node>
<node id="Member State">
  <data key="d0">Member State</data>
  <data key="d1">location</data>
  <data key="d2">Member State refers to any state that is a member of the European Union.&lt;SEP&gt;Member State is a country within the European Union that is designated or establishes a notifying authority.&lt;SEP&gt;Member State is a generic term referring to the member countries of the European Union.&lt;SEP&gt;Member State is a location where market surveillance authorities operate and issue authorizations.&lt;SEP&gt;Member State is a country that is a part of the European Union and is under the jurisdiction of the EU regulations.</data>
  <data key="d3">chunk-9bbabb917a8fd4d1cab0f28da3292879&lt;SEP&gt;chunk-0c7d4abb8fe7eae2c8001f5fd07e1ba9&lt;SEP&gt;chunk-414727d1a6d237ecc9306035920d4685&lt;SEP&gt;chunk-2cddb0815e714f4234b0eb77a0886db3&lt;SEP&gt;chunk-3235bf9304fec9e624bfd76288a19b57</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1779828334</data>
  <data key="d6"></data>
</node>
<node id="Notifying Authorities">
  <data key="d0">Notifying Authorities</data>
  <data key="d1">artifact</data>
  <data key="d2">Notifying Authorities are organizations designated by the Member State to communicate information to the Commission.</data>
  <data key="d3">chunk-9bbabb917a8fd4d1cab0f28da3292879&lt;SEP&gt;chunk-351f07fc1cfb91436e9dffcf5c8e88df</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1779828334</data>
  <data key="d6"></data>
</node>
<node id="Single Point of Contact">
  <data key="d0">Single Point of Contact</data>
  <data key="d1">artifact</data>
  <data key="d2">Single Point of Contact is a designated authority to act as the focal point for communication under various regulations.</data>
  <data key="d3">chunk-9bbabb917a8fd4d1cab0f28da3292879</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1779828334</data>
  <data key="d6"></data>
</node>
<node id="National Competent Authorities">
  <data key="d0">National Competent Authorities</data>
  <data key="d1">organization</data>
  <data key="d2">National Competent Authorities are responsible for requesting documentation from providers.&lt;SEP&gt;National authorities can be involved in the compliance process for AI models.&lt;SEP&gt;National Competent Authorities are the bodies responsible for supervising AI regulatory sandboxes at the national level.&lt;SEP&gt;National Competent Authorities are entities responsible for implementing and enforcing EU regulations within their respective countries.&lt;SEP&gt;National Competent Authorities are authorities responsible for applying the Regulation within their respective countries.&lt;SEP&gt;National Competent Authorities are government bodies responsible for enforcing regulatory compliance.&lt;SEP&gt;National Competent Authorities are responsible for enforcement and reporting to the Commission.</data>
  <data key="d3">chunk-9bbabb917a8fd4d1cab0f28da3292879&lt;SEP&gt;chunk-d9ca73b5aa4562e502c8b54d80b9091a&lt;SEP&gt;chunk-91245f3945c3d7cc7ebcd77b066b7ef9&lt;SEP&gt;chunk-3b09e19ff232fc74f764b77ba6bcc3f4&lt;SEP&gt;chunk-1ba7997e7cc9a9c81f53126131569e4a&lt;SEP&gt;chunk-3e2911d860a9f8426e67a536486d6752&lt;SEP&gt;chunk-9d3918796c66f4ec90d4e54c0693276f</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1779828334</data>
  <data key="d6"></data>
</node>
<node id="AI Technologies, Data and Data Computing">
  <data key="d0">AI Technologies, Data and Data Computing</data>
  <data key="d1">concept</data>
  <data key="d2">AI Technologies, Data and Data Computing encompass the techniques, methodologies, and aspects of artificial intelligence that are integral to the functioning of AI systems.</data>
  <data key="d3">chunk-9bbabb917a8fd4d1cab0f28da3292879</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1779828334</data>
  <data key="d6"></data>
</node>
<node id="Personal Data Protection">
  <data key="d0">Personal Data Protection</data>
  <data key="d1">concept</data>
  <data key="d2">Personal Data Protection involves the safeguarding of personal information and ensuring compliance with data privacy laws.</data>
  <data key="d3">chunk-9bbabb917a8fd4d1cab0f28da3292879</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1779828334</data>
  <data key="d6"></data>
</node>
<node id="Cybersecurity">
  <data key="d0">Cybersecurity</data>
  <data key="d1">concept</data>
  <data key="d2">Cybersecurity refers to the protection of information systems from theft or damage to the hardware, software, or data, as well as from disruption or unauthorized access.</data>
  <data key="d3">chunk-9bbabb917a8fd4d1cab0f28da3292879</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1779828334</data>
  <data key="d6"></data>
</node>
<node id="Fundamental Rights">
  <data key="d0">Fundamental Rights</data>
  <data key="d1">concept</data>
  <data key="d2">Fundamental rights refer to the basic entitlements and freedoms inherent to human dignity and basic human rights as recognized by the European Union law.&lt;SEP&gt;Fundamental Rights encompass the legal and ethical principles that must be respected when developing and deploying AI systems.&lt;SEP&gt;Fundamental Rights cover civil liberties and rights that the AI system must not infringe upon.</data>
  <data key="d3">chunk-9bbabb917a8fd4d1cab0f28da3292879&lt;SEP&gt;chunk-612e9d6ebed2e9c1601b0ed553a37ca2&lt;SEP&gt;chunk-2d5febc258257152890296838762d806</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1779828334</data>
  <data key="d6"></data>
</node>
<node id="Health and Safety Risks">
  <data key="d0">Health and Safety Risks</data>
  <data key="d1">concept</data>
  <data key="d2">Health and Safety Risks are potential hazards that can affect the well-being of individuals in the context of AI system deployment.&lt;SEP&gt;Health and Safety Risks include potential harms to users and the environment from the AI system.</data>
  <data key="d3">chunk-9bbabb917a8fd4d1cab0f28da3292879&lt;SEP&gt;chunk-612e9d6ebed2e9c1601b0ed553a37ca2</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1779828335</data>
  <data key="d6"></data>
</node>
<node id="Annex VIII">
  <data key="d0">Annex VIII</data>
  <data key="d1">artifact</data>
  <data key="d2">Annex VIII is a section containing specific points related to registration information.&lt;SEP&gt;Annex VIII is a supplementary document detailing data to be entered into the EU database.</data>
  <data key="d3">chunk-9bbabb917a8fd4d1cab0f28da3292879&lt;SEP&gt;chunk-4d317a57f8826116be7899af7bef32dd</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1779828335</data>
  <data key="d6"></data>
</node>
<node id="Post-Market Monitoring System">
  <data key="d0">Post-Market Monitoring System</data>
  <data key="d1">artifact</data>
  <data key="d2">Post-Market Monitoring System is a system for gathering data on the performance and safety of AI systems after they are deployed.&lt;SEP&gt;Post-Market Monitoring System involves the processes and strategies used to monitor the performance of AI systems after their deployment.</data>
  <data key="d3">chunk-9bbabb917a8fd4d1cab0f28da3292879&lt;SEP&gt;chunk-2d5febc258257152890296838762d806</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1779828335</data>
  <data key="d6"></data>
</node>
<node id="Annex IV">
  <data key="d0">Annex IV</data>
  <data key="d1">artifact</data>
  <data key="d2">Annex IV contains the minimum elements required in the technical documentation for high-risk AI systems.&lt;SEP&gt;Annex IV is a supplementary document that provides technical documentation for the post-market monitoring plan of AI systems.&lt;SEP&gt;Annex IV is a section of the document that includes the post-market monitoring plan in the technical documentation.&lt;SEP&gt;Annex IV to the Regulation contains technical documentation details.&lt;SEP&gt;Annex IV contains technical documentation requirements.</data>
  <data key="d3">chunk-9bbabb917a8fd4d1cab0f28da3292879&lt;SEP&gt;chunk-8c4a20c7ba57c9d3c1ba3d58548d1390&lt;SEP&gt;chunk-3b09e19ff232fc74f764b77ba6bcc3f4&lt;SEP&gt;chunk-f4bd0831e0cdcbfe10ebd94d84d35ece&lt;SEP&gt;chunk-9aeb5afbd1a4b894acf12c446410f902</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1779828335</data>
  <data key="d6"></data>
</node>
<node id="Providers">
  <data key="d0">Providers</data>
  <data key="d1">organization</data>
  <data key="d2">Providers are organizations responsible for the provision of AI systems.&lt;SEP&gt;Providers are entities that provide high-risk AI systems and are subject to the obligations outlined in the regulation.&lt;SEP&gt;Providers are organizations or entities that create and distribute AI systems.</data>
  <data key="d3">chunk-49852a3ba29135f33f5a66d5530afe75&lt;SEP&gt;chunk-4d317a57f8826116be7899af7bef32dd&lt;SEP&gt;chunk-6d534e37e8a91e087b0f7afd91260337&lt;SEP&gt;chunk-b46993509f7f45efc7114ce53d7712a1</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1779828335</data>
  <data key="d6"></data>
</node>
<node id="Notified Bodies">
  <data key="d0">Notified Bodies</data>
  <data key="d1">organization</data>
  <data key="d2">Notified Bodies are entities responsible for the conformity assessment of high-risk AI systems.&lt;SEP&gt;Notified Bodies issue certificates for high-risk AI systems.&lt;SEP&gt;Notified Bodies are bodies authorized to assess the compliance of certain products with mandatory standards and regulations.&lt;SEP&gt;Notified Bodies are entities involved in the application of the Regulation, respecting confidentiality obligations.&lt;SEP&gt;Notified Bodies are entities designated by regulatory authorities to assess compliance with certain standards.&lt;SEP&gt;Notified Bodies are regulated entities that assess compliance with certain standards.</data>
  <data key="d3">chunk-49852a3ba29135f33f5a66d5530afe75&lt;SEP&gt;chunk-3b09e19ff232fc74f764b77ba6bcc3f4&lt;SEP&gt;chunk-1ba7997e7cc9a9c81f53126131569e4a&lt;SEP&gt;chunk-9aeb5afbd1a4b894acf12c446410f902&lt;SEP&gt;chunk-9d3918796c66f4ec90d4e54c0693276f</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1779828335</data>
  <data key="d6"></data>
</node>
<node id="EU Declaration of Conformity">
  <data key="d0">EU Declaration of Conformity</data>
  <data key="d1">document</data>
  <data key="d2">The EU Declaration of Conformity refers to a document required for high-risk AI systems.&lt;SEP&gt;EU Declaration of Conformity is a document declaring that a product meets the essential requirements of the relevant EU directives.&lt;SEP&gt;EU Declaration of Conformity is a document confirming compliance with the relevant regulations.&lt;SEP&gt;EU Declaration of Conformity is a document indicating that an AI system meets the specific requirements and criteria set by regulatory authorities.</data>
  <data key="d3">chunk-49852a3ba29135f33f5a66d5530afe75&lt;SEP&gt;chunk-c5974c0c87096acad0b2aac605ef8802&lt;SEP&gt;chunk-612e9d6ebed2e9c1601b0ed553a37ca2&lt;SEP&gt;chunk-2af337ff23074191f5e5e0bdd26073d1</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1779828335</data>
  <data key="d6"></data>
</node>
<node id="Competent Authorities">
  <data key="d0">Competent Authorities</data>
  <data key="d1">organization</data>
  <data key="d2">Competent Authorities are governmental bodies responsible for the oversight of high-risk AI systems.&lt;SEP&gt;Competent Authorities are responsible for overseeing and providing support for the establishment and operation of AI regulatory sandboxes.</data>
  <data key="d3">chunk-49852a3ba29135f33f5a66d5530afe75&lt;SEP&gt;chunk-95f4bd1a2188c8af0ad581dae55c8d76</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1779828335</data>
  <data key="d6"></data>
</node>
<node id="Union Law">
  <data key="d0">Union Law</data>
  <data key="d1">legislation</data>
  <data key="d2">Union Law refers to the laws of the European Union.&lt;SEP&gt;Union Law refers to the legal framework of the European Union that sets standards and requirements for high-risk AI systems.&lt;SEP&gt;Union law refers to the legal framework of the European Union that provides for measures to prevent or minimize risks posed by AI systems.&lt;SEP&gt;Union Law includes legal frameworks governing high-risk AI systems and their documentation.&lt;SEP&gt;Union Law encompasses both EU Directives and Regulations and guides the obligations and procedures for handling AI systems.</data>
  <data key="d3">chunk-49852a3ba29135f33f5a66d5530afe75&lt;SEP&gt;chunk-0c7d4abb8fe7eae2c8001f5fd07e1ba9&lt;SEP&gt;chunk-2d5febc258257152890296838762d806&lt;SEP&gt;chunk-51ee6686c61ba5ea54245e3aa87b1783&lt;SEP&gt;chunk-0c328886326bda8019859ce49acc29cc</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1779828335</data>
  <data key="d6"></data>
</node>
