  <data key="d1">concept</data>
  <data key="d2">Performance of an AI system refers to its ability to achieve its intended purpose.</data>
  <data key="d3">chunk-5303a356a94e477f040c55c8fb0446c1</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1779828350</data>
  <data key="d6"></data>
</node>
<node id="notifying authority">
  <data key="d0">notifying authority</data>
  <data key="d1">organization</data>
  <data key="d2">A notifying authority is a national authority responsible for setting up and carrying out necessary procedures for the assessment, designation, and notification of conformity assessment bodies.</data>
  <data key="d3">chunk-5303a356a94e477f040c55c8fb0446c1</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1779828350</data>
