  <data key="d1">concept</data>
  <data key="d2">AI Practices are the specific activities or methods related to artificial intelligence that may be restricted or banned.</data>
  <data key="d3">chunk-9d3918796c66f4ec90d4e54c0693276f</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1779828349</data>
  <data key="d6"></data>
</node>
<node id="Administrative Fine">
