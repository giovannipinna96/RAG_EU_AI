<node id="Asylum">
  <data key="d0">Asylum</data>
  <data key="d1">concept</data>
  <data key="d2">Asylum refers to the protection granted to individuals who fear persecution in their home countries.&lt;SEP&gt;Asylum refers to the international legal protection offered to individuals who face persecution in their home countries.</data>
  <data key="d3">chunk-33b3b690e83a48d4f90c85be3eebb646&lt;SEP&gt;chunk-89493349bc2eb2b0fa14e08d5114b0a5</data>
