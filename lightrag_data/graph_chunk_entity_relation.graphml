<node id="Qualified Alert">
  <data key="d0">Qualified Alert</data>
  <data key="d1">concept</data>
  <data key="d2">A Qualified Alert is issued by the Scientific Panel when there is a reasonable suspicion of a systemic risk posed by a general-purpose AI model.&lt;SEP&gt;A qualified alert issued by the scientific panel triggers evaluations of general-purpose AI models with systemic risk.</data>
  <data key="d3">chunk-51ee6686c61ba5ea54245e3aa87b1783&lt;SEP&gt;chunk-b46993509f7f45efc7114ce53d7712a1</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1779828347</data>
  <data key="d6"></data>
</node>
<node id="Investigation">
  <data key="d0">Investigation</data>
  <data key="d1">method</data>
  <data key="d2">Investigation involves the examination and evaluation of the concerns raised by the qualified alert for systemic risks posed by AI models.</data>
  <data key="d3">chunk-51ee6686c61ba5ea54245e3aa87b1783</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1779828347</data>
  <data key="d6"></data>
