<node id="article 15">
  <data key="d0">article 15</data>
  <data key="d1">event</data>
  <data key="d2">Article 15 is a guideline for ensuring that high-risk AI systems achieve appropriate levels of accuracy, robustness, and cybersecurity.</data>
