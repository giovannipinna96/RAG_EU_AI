<node id="high-risk ai system">
  <data key="d0">high-risk ai system</data>
  <data key="d1">artifact</data>
  <data key="d2">High-risk AI systems are AI systems designed for purposes that could impact health, safety, or fundamental rights significantly.</data>
  <data key="d3">chunk-83433e14f479755aaaf16c96e5408e58</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1779828348</data>
  <data key="d6"></data>
</node>
<node id="human oversight">
  <data key="d0">human oversight</data>
  <data key="d1">concept</data>
  <data key="d2">Human oversight refers to the supervision provided by natural persons to high-risk AI systems to prevent or minimize risks.</data>
  <data key="d3">chunk-83433e14f479755aaaf16c96e5408e58</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1779828348</data>
  <data key="d6"></data>
</node>
<node id="human-machine interface tool">
  <data key="d0">human-machine interface tool</data>
  <data key="d1">method</data>
  <data key="d2">Human-machine interface tools are tools designed to facilitate interaction and understanding between human users and the AI systems.</data>
  <data key="d3">chunk-83433e14f479755aaaf16c96e5408e58</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1779828348</data>
  <data key="d6"></data>
</node>
<node id="capacity and limitations">
  <data key="d0">capacity and limitations</data>
  <data key="d1">concept</data>
  <data key="d2">Capacity and limitations refer to the functional and operational constraints of an AI system as understood by its users.</data>
  <data key="d3">chunk-83433e14f479755aaaf16c96e5408e58</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1779828348</data>
  <data key="d6"></data>
</node>
<node id="automation bias">
  <data key="d0">automation bias</data>
  <data key="d1">concept</data>
  <data key="d2">Automation bias is the tendency of users to rely excessively on AI outputs, potentially leading to reduced decision-making accuracy.</data>
  <data key="d3">chunk-83433e14f479755aaaf16c96e5408e58</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1779828348</data>
  <data key="d6"></data>
</node>
<node id="stop button">
  <data key="d0">stop button</data>
  <data key="d1">artifact</data>
  <data key="d2">A stop button is a physical or digital mechanism used to halt an AI system's operation safely.</data>
  <data key="d3">chunk-83433e14f479755aaaf16c96e5408e58</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1779828348</data>
