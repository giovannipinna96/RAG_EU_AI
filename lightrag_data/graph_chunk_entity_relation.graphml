  <data key="d0">Natural Person</data>
  <data key="d1">person</data>
  <data key="d2">Natural Person refers to an individual human being.&lt;SEP&gt;Natural Person refers to a human being.</data>
  <data key="d3">chunk-6d534e37e8a91e087b0f7afd91260337&lt;SEP&gt;chunk-33b3b690e83a48d4f90c85be3eebb646</data>
  <data key="d4">unknown_source</data>
